{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Marietta",
  "scopeName": "source.marietta",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#actors" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.marietta"
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|else|while|for|in|return|pass|break|continue)\\b",
          "name": "keyword.control.marietta"
        },
        {
          "match": "\\b(def|var|let)\\b",
          "name": "keyword.declaration.marietta"
        },
        {
          "match": "\\b(actor|spawn|send|recv)\\b",
          "name": "keyword.other.actor.marietta"
        },
        {
          "match": "\\b(async|await)\\b",
          "name": "keyword.control.async.marietta"
        },
        {
          "match": "\\bself\\b",
          "name": "variable.language.self.marietta"
        }
      ]
    },
    "types": {
      "match": "\\b(u1|u8|u16|u32|u64|u128|u256|u512|u1024|u2048|f32|f64|bool|channel)\\b",
      "name": "storage.type.marietta"
    },
    "constants": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.marietta"
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.marietta",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.marietta"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b[0-9]+\\.[0-9]+\\b",
          "name": "constant.numeric.float.marietta"
        },
        {
          "match": "\\b0x[0-9a-fA-F]+\\b",
          "name": "constant.numeric.hex.marietta"
        },
        {
          "match": "\\b[0-9]+\\b",
          "name": "constant.numeric.integer.marietta"
        }
      ]
    },
    "actors": {
      "match": "(?<=\\bactor\\s)([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "entity.name.type.actor.marietta" }
      }
    },
    "functions": {
      "patterns": [
        {
          "match": "(?<=\\bdef\\s)([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.marietta" }
          }
        },
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.marietta" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "->",
          "name": "punctuation.separator.return-type.marietta"
        },
        {
          "match": "\\b(and|or|not)\\b",
          "name": "keyword.operator.logical.marietta"
        },
        {
          "match": "<=|>=|==|!=|<|>",
          "name": "keyword.operator.comparison.marietta"
        },
        {
          "match": "\\+=|-=|\\*=|/=|%=|=",
          "name": "keyword.operator.assignment.marietta"
        },
        {
          "match": "\\+|-|\\*|/|%",
          "name": "keyword.operator.arithmetic.marietta"
        },
        {
          "match": ":",
          "name": "punctuation.separator.type-annotation.marietta"
        }
      ]
    }
  }
}
